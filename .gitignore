# ignore build artifacts and thirdparty dependencies that are generated by Scons
/build
# /thirdparty is downloaded/built by scons — ignore it all EXCEPT the
# vendored generate_stubs generator, which is source we ship.
/thirdparty/*
!/thirdparty/generate_stubs
# scratch build-timing files
.build_start
.build_end
# dlopen dispatch table emitted from flow/ports/idtx_core.sigs by
# scons/generate_stubs.py — regenerated per-platform at build time
# (POSIX stub .cc/.h use forward slashes, Windows .def differs), so it's
# a build artifact, not source.
/flow/ports/generated
/venv
.sconsign.dblite
/addons/*/bin
/addons/IDTXFlow/LICENSES-THIRD-PARTY
/addons/IDTXFlow/THIRDPARTY.txt
# pixi solved environments (web/viser-host) — regenerated from pixi.toml/lock
**/.pixi/
# node / web build outputs (global — don't rely on per-project .gitignore)
**/node_modules/
/web/*/dist/
# Claude Code runtime state (loop/scheduler locks)
/.claude/scheduled_tasks.lock
*/**/__pycache__
/flow/adapters/godot/src/gen
/templates/extension_template/thirdparty
/templates/extension_template/build
/templates/extension_template/addons/*/bin

# ignore editor configurations
/.vscode
/.idea
IDTXFlowGodot.sln.DotSettings.user
*.swp
*.swo
*~
*.bak

# ignore OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Unity-side build artefacts in case the IdtxCore package is dropped
# into a Unity project living inside this tree. The package itself
# (flow/adapters/unity/IdtxCore/Plugins, /Bridge, package.json,
# README.md) stays tracked; only Unity's per-project caches are excluded.
flow/adapters/unity/**/Library/
flow/adapters/unity/**/Temp/
flow/adapters/unity/**/Obj/
flow/adapters/unity/**/Build/
flow/adapters/unity/**/Logs/
flow/adapters/unity/**/UserSettings/
flow/adapters/unity/**/MemoryCaptures/
flow/adapters/unity/**/*.csproj
flow/adapters/unity/**/*.sln
flow/adapters/unity/**/*.user
flow/adapters/unity/**/*.meta.bak

# ignore binary files that will be generated by the build process
*.dll
*.so
*.dylib
*.exp
*.lib
*.pdb
*.obj
*.ilk
*.os
*.o
*.a
idtx-build.log

# Test runners / dev caches
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/

# avatar pipeline binary outputs — produced by the smoke test (under
# /build/idtxcli/ which is already ignored) and by ad-hoc CLI runs.
# Listed explicitly so they don't slip in if someone runs idtxcli
# from another working directory.
*.vrm
*.glb

# Godot project (repo root IS the Godot project: project.godot + addons/).
# The editor's import cache regenerates; the Miroir scenes are transient
# cross-engine transfer demo output (the USD/JSON the spokes exchange).
/.godot/
/Miroir_Re_fromUnity_USD.tscn
/Miroir_Re_Clothing_fromUnity.tscn
/miroir_geo.json

# Unity-deployed OpenUSD plugin tree (build artifact, see scons/idtxcore.py)
flow/adapters/unity/IdtxCore/Plugins/*/usd~/
compile_commands.json
__pycache__/
