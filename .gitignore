# ignore build artifacts and thirdparty dependencies that are generated by Scons
/build
/thirdparty
/venv
.sconsign.dblite
/addons/*/**/bin
/addons/IDTXFlow/LICENSES-THIRD-PARTY
/addons/IDTXFlow/THIRDPARTY.txt
*/**/__pycache__
/source/gen
/templates/extension_template/thirdparty
/templates/extension_template/build
/templates/extension_template/addons/*/**/bin

# ignore editor configurations
/.vscode
/.idea
IDTXFlowGodot.sln.DotSettings.user

# ignore binary files that will be generated by the build process
*.dll
*.so
*.dylib
*.exp
*.lib
*.pdb
*.obj
*.os
*.o
*.a
