int32_t idtx_mesh_get_face_vertex_count_count(const idtx_mesh_t* mesh);
void idtx_mesh_get_face_vertex_counts(const idtx_mesh_t* mesh, int32_t* out_counts);
int32_t idtx_mesh_get_vertex_count(const idtx_mesh_t* mesh);
int32_t idtx_mesh_get_index_count(const idtx_mesh_t* mesh);
int32_t idtx_mesh_get_bones_per_vertex(const idtx_mesh_t* mesh);
void idtx_mesh_get_positions(const idtx_mesh_t* mesh, float* out_positions);
void idtx_mesh_get_normals(const idtx_mesh_t* mesh, float* out_normals);
void idtx_mesh_get_uvs(const idtx_mesh_t* mesh, float* out_uvs);
void idtx_mesh_get_colors(const idtx_mesh_t* mesh, float* out_colors);
void idtx_mesh_get_indices(const idtx_mesh_t* mesh, int32_t* out_indices);
void idtx_mesh_get_bone_indices(const idtx_mesh_t* mesh, int32_t* out_bone_indices);
void idtx_mesh_get_weights(const idtx_mesh_t* mesh, float* out_weights);
int32_t idtx_mesh_has_normals(const idtx_mesh_t* mesh);
int32_t idtx_mesh_has_uvs(const idtx_mesh_t* mesh);
int32_t idtx_mesh_has_colors(const idtx_mesh_t* mesh);
int32_t idtx_mesh_reconstruct_quads(idtx_mesh_t* mesh, float planarity_max_degrees);

