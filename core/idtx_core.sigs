# --- Top-level I/O: USD (flat + layer-aware), VRM, Godot .scn ----------
int32_t idtx_core_export_avatar_to_usd(const idtx_avatar_t* avatar, const char* path);
void idtx_usd_export_opts_init(idtx_usd_export_opts_t* opts);
int32_t idtx_core_export_avatar_to_usd_ex(const idtx_avatar_t* avatar, const char* path, const idtx_usd_export_opts_t* opts);
idtx_avatar_t* idtx_core_import_avatar_from_usd(const char* path);
int32_t idtx_core_export_avatar_to_vrm(const idtx_avatar_t* avatar, const char* path);
idtx_avatar_t* idtx_core_import_avatar_from_vrm(const char* path);
void idtx_scn_opts_init(idtx_scn_opts_t* opts);
int32_t idtx_core_export_avatar_to_scn(const idtx_avatar_t* avatar, const char* path, const idtx_scn_opts_t* opts);
int64_t idtx_core_export_avatar_to_scn_buffer(const idtx_avatar_t* avatar, uint8_t* out_buf, size_t out_cap, const idtx_scn_opts_t* opts);
