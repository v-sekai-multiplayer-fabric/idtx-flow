# libidtx_core C ABI — function declarations consumed by every host that
# dlopens the core (Godot GDExtension, Unity P/Invoke, Unreal plugin,
# Blender hook, and the standalone idtxcli). Fed to
# thirdparty/generate_stubs/generate_stubs.py, which emits a dlsym-backed
# dispatch table (POSIX stubs) / delay-load .def (Windows) — no
# -lidtx_core at link time, and therefore no transitive OpenUSD on any
# host's link line. The host loads libidtx_core.<plat>.<arch>.<ext> at
# runtime and calls through the generated table.
#
# This file is the single source of truth for the exported ABI. It must
# stay in lockstep with core/include/idtx_core/idtx_core.h — the SCons
# step diffs the two so a new IDTX_CORE_API export without a matching
# line here (or vice versa) fails the build.
#
# Format: one C-style declaration per line. Comments start with '#'.
# Opaque handle types, enums, and option structs come from idtx_core.h,
# included via the generated stubs' compat header.

# --- Library lifecycle -------------------------------------------------
const char* idtx_core_version(void);
int32_t idtx_core_init(const char* plugin_dir);
void idtx_core_set_progress_cb(idtx_progress_fn cb, void* user);

# --- idtx_skeleton -----------------------------------------------------
idtx_skeleton_t* idtx_skeleton_create(void);
void idtx_skeleton_destroy(idtx_skeleton_t* skel);
void idtx_skeleton_set_name(idtx_skeleton_t* skel, const char* name);
const char* idtx_skeleton_get_name(const idtx_skeleton_t* skel);
int32_t idtx_skeleton_add_bone(idtx_skeleton_t* skel, const char* name, int32_t parent_index, const float rest_matrix[16], const float bind_matrix[16]);
int32_t idtx_skeleton_get_bone_count(const idtx_skeleton_t* skel);
const char* idtx_skeleton_get_bone_name(const idtx_skeleton_t* skel, int32_t index);
int32_t idtx_skeleton_get_bone_parent(const idtx_skeleton_t* skel, int32_t index);
void idtx_skeleton_get_bone_rest(const idtx_skeleton_t* skel, int32_t index, float out_matrix[16]);
void idtx_skeleton_get_bone_bind(const idtx_skeleton_t* skel, int32_t index, float out_matrix[16]);
void idtx_skeleton_set_bone_rest(idtx_skeleton_t* skel, int32_t index, const float matrix[16]);
void idtx_skeleton_set_bone_bind(idtx_skeleton_t* skel, int32_t index, const float matrix[16]);

# --- idtx_mesh ---------------------------------------------------------
